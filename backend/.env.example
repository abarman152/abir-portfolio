# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Use the "Transaction" pooler URL from Supabase → Project Settings → Database
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-64-char-random-string"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV="development"

# ─── CORS ────────────────────────────────────────────────────────────────────
# Production: https://abirbarman.com
FRONTEND_URL="http://localhost:3000"

# ─── Media (Cloudinary) ──────────────────────────────────────────────────────
# From Cloudinary Dashboard → API Keys → copy the full CLOUDINARY_URL value
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
